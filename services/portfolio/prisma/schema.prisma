generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/client/portfolio"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  assetSymbol     String
  amount          Float
  transactionType String   // "BUY" or "SELL"
  createdAt       DateTime @default(now())
}
